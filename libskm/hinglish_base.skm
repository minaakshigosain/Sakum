#            fail_close(handle) -> void
#            fail_exists(path) -> bool
#            fail_delete(path) -> void
.section .text.hinglish
FUNC fail_open
    SKM_PROLOGUE 0
    // open(2) syscall
    SKM_EPILOGUE
.endfunc

