#            jaal_resolve(hostname) -> str  (IP address)
.section .text.hinglish
FUNC jaal_socket
    SKM_PROLOGUE 0
    // socket(2) syscall
    SKM_EPILOGUE
.endfunc

# ── कुंजी (Kunjee) — Cryptography ──────────────────────────────
# Signature: kunjee_aes_encrypt(plain, key, len) -> cipher
#            kunjee_aes_decrypt(cipher, key, len) -> plain
#            kunjee_sha256(data, len) -> hash (32 bytes)
#            kunjee_hmac(data, key, len) -> mac (32 bytes)
#            kunjee_rand_bytes(buf, len) -> void
#            kunjee_keygen() -> key (32 bytes)
.section .text.hinglish
FUNC kunjee_sha256
    SKM_PROLOGUE 0
    // SHA-256 implementation using architecture crypto extensions
    // or software fallback
    SKM_EPILOGUE
.endfunc

# ── परीक्षा (Pareeksha) — Testing framework ────────────────────
# Signature: pareeksha_start(name) -> void
#            pareeksha_assert(condition, message) -> void
#            pareeksha_eq(actual, expected, name) -> void
#            pareeksha_report() -> void
.section .text.hinglish
FUNC pareeksha_start
    SKM_PROLOGUE 0
    SKM_EPILOGUE
.endfunc

# ── Module initialisation ──────────────────────────────────────
.section .init.hinglish
FUNC hinglish_base_init
    SKM_PROLOGUE 0
    // Register all Hinglish functions in the global symbol table
    // so they are automatically linked when a Sakum program uses
    // the Hindi keyword or its English alias.
    //
    // Registration table:
    //   "lekh\0"       → lekh
    //   "padho\0"      → padho
    //   "ganit_add\0"  → ganit_add
    //   ...
    //   "pareeksha_report\0" → pareeksha_report
    SKM_EPILOGUE
.endfunc

# ── Module exports (for .skm symbol table) ────────────────────
.section .exports
    .quad lekh
    .asciz "lekh"
    .quad padho
    .asciz "padho"
    .quad ganit_add
    .asciz "ganit_add"
    .quad ganit_sqrt
    .asciz "ganit_sqrt"
    .quad ganit_rand
    .asciz "ganit_rand"
    .quad samay_now
    .asciz "samay_now"
    .quad sarni_new
    .asciz "sarni_new"
    .quad shabd_len
    .asciz "shabd_len"
    .quad shabd_to_int
    .asciz "shabd_to_int"
    .quad shabd_from_int
    .asciz "shabd_from_int"
    .quad fail_open
    .asciz "fail_open"
    .quad jaal_socket
    .asciz "jaal_socket"
    .quad kunjee_sha256
    .asciz "kunjee_sha256"
    .quad pareeksha_start
    .asciz "pareeksha_start"
