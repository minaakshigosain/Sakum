naam x = 10;
lek(x);

yadi (x > 5) {
  lek("बृहत्");
} anyatha {
  lek("लघु");
}

yavat (x > 0) {
  lek(x);
  x = x - 1;
}

kriya योग(a, b) {
  vapsa a + b;
}
lek(योग(3, 4));

naam v = vec(1, 2, 3);
lek(latex(v));

naam q = qubit(1);
lek(measure(q));

lek(query("learn from mistake in memory"));
lek(sutra_key());
lek(heartbeat());
