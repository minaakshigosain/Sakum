नाम x = 10;
लेख(x);

यदि (x > 5) {
  लेख("बृहत्");
} अन्यथा {
  लेख("लघु");
}

यावत् (x > 0) {
  लेख(x);
  x = x - 1;
}

क्रिया योग(a, b) {
  प्रत्यागम a + b;
}
लेख(योग(3, 4));

नाम v = vec(1, 2, 3);
लेख(latex(v));

नाम q = qubit(1);
लेख(measure(q));

लेख(query("learn from mistake in memory"));
लेख(sutra_key());
लेख(heartbeat());
